# Frontend: copy → `.env` in this folder (same level as package.json).
# Vite only loads `.env*` — `.env.example` is NOT applied automatically.

# --- Local backend (runs on port 8000) ---
VITE_API_BASE_URL=https://cox-solution-api.vercel.app

# --- Production API on Vercel (no trailing slash) — switch to this for deployed admin / prod build ---
# VITE_API_BASE_URL=https://cox-solution-api.vercel.app

# Dev server binding
VITE_FRONTEND_HOST=127.0.0.1
VITE_PORT=5173
