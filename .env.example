# Frontend (copy to `.env`). Vite only reads `VITE_*` at build/runtime.

# Local dev – API on your machine (no trailing slash)
VITE_API_BASE_URL=https://cox-solution-api.vercel.app

# Production – deployed Node API on Vercel (no trailing slash)
# Use this when you build/deploy the frontend so login and all APIs hit the cloud backend:
# VITE_API_BASE_URL=https://cox-backend.vercel.app

# Frontend dev server
VITE_FRONTEND_HOST=127.0.0.1
VITE_PORT=5173
