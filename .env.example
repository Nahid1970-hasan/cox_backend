
PORT=8000

PUBLIC_BASE_URL=http://127.0.0.1:8000
# PUBLIC_BASE_URL=https://cox-backend.vercel.app

# MySQL (required). On Vercel use a hosted DB — not 127.0.0.1.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cox_solution

# Most cloud MySQL require TLS (PlanetScale, Railway, etc.)
# MYSQL_SSL=1

# Skip RUNTIME schema apply (DB already migrated). Optional on Vercel.
# SKIP_DB_BOOTSTRAP=true

# Show full error text in 503 JSON on Vercel (dev only)
# API_DEBUG_ERRORS=1

JWT_SECRET=change-this-to-a-long-random-string-in-production

DEFAULT_NEW_USER_PASSWORD=TempPass123!

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

FRONTEND_ORIGIN=http://127.0.0.1:5173
# Production example:
# FRONTEND_ORIGIN=https://cox-solution-admin.vercel.app
