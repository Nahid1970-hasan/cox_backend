# Copy to .env and adjust for your machine.

PORT=8000

# Base URL returned for uploaded files (no trailing slash).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# MySQL — ensure MySQL Server is running. On startup the API creates MYSQL_DATABASE + tables from schema.sql if needed.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cox_solution

JWT_SECRET=change-this-to-a-long-random-string-in-production

# Used when creating a user without a password from the admin UI.
DEFAULT_NEW_USER_PASSWORD=TempPass123!

# First-run seed when users table is empty (plaintext — change after login).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

# Browser origin(s) for CORS — comma-separated for multiple. Vite defaults are allowed automatically (127.0.0.1:5173 and localhost:5173).
FRONTEND_ORIGIN=http://127.0.0.1:5173
