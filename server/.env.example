# Copy to server/.env and adjust. On Vercel, set these in Project → Settings → Environment Variables.

PORT=8000

# Public URL of THIS API — used for absolute upload URLs etc. NO trailing slash.
# Local:
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Production (Vercel API):
# PUBLIC_BASE_URL=https://cox-backend.vercel.app

# MySQL — ensure MySQL is running before starting the API.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cox_solution

JWT_SECRET=change-this-to-a-long-random-string-in-production

DEFAULT_NEW_USER_PASSWORD=TempPass123!

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

# CORS — browser origin(s) allowed to call this API (comma-separated, no trailing slash).
# Include your deployed admin SPA:
FRONTEND_ORIGIN=http://127.0.0.1:5173
# Production example:
# FRONTEND_ORIGIN=https://cox-solution-admin.vercel.app,http://127.0.0.1:5173
